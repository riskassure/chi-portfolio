# ==========================================================================
# 🗄️ DATABASE & STRUCTURED LOCAL ENVIRONMENT FILES
# ==========================================================================
# Block local runtime database engines
backend/portfolio.db
backend/*.db

# ==========================================================================
# 🐍 PYTHON SYSTEM RUNTIMES & CACHE
# ==========================================================================
# Block local computer-compiled execution files
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# ==========================================================================
# 🎵 MUSIC MODULE DATA PIPELINES
# ==========================================================================
# Block raw tracker sheets and ALL processed JSON data dumps in this folder
backend/data/music/raw/*.csv
backend/data/music/processed/*.json

# ==========================================================================
# 📸 PHOTOGRAPHY ASSET GUARDRAILS
# ==========================================================================
# Block heavy, uncompressed raw landscape source assets
backend/data/photos/raw/

# ==========================================================================
# 💻 EDITOR & OPERATING SYSTEM JUNK
# ==========================================================================
.vscode/
.DS_Store
Thumbs.db

# ==========================================================================
# 🧮 MATHEMATICS GENERATED ASSETS
# ==========================================================================
# Block generated PSTricks/SVG conversion outputs and temporary LaTeX build files
backend/data/math/diagrams/
backend/data/math/temp/

# Block generated math diagnostics reports
backend/data/math/rendered_tex_diagnostics.csv
backend/data/math/pmlinkname_target_diagnostics.csv