# Ignore the local SQLite database file
backend/portfolio.db
*.db

# Ignore all raw CSV files holding your original playlist downloads
backend/data/raw/*.csv
*.csv

# Optional: If you want your individual JSON files to stay local for future DB work, 
# but keep the master file public for the frontend, you can ignore the specific ones:
backend/data/processed/*_playlist.json

